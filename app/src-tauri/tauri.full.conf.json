{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Warframe Profile",
  "version": "1.0.0",
  "identifier": "com.warframe.profile.full",
  "build": {
    "beforeDevCommand": "pnpm vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Warframe Profile",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": { "language": "zh-CN" }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVCM0M1Nzg0OTREMjYyNzQKUldSMFl0S1VoRmM4VzMxNjRTOVFka2ltMDNsbDIwU1phSGU3cUc0RDNQMWR5b0lXcTNMZld4c0IK",
      "endpoints": [
        "https://github.com/wxhn1225/warframe-profile/releases/latest/download/latest-full.json"
      ]
    }
  }
}
